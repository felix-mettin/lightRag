    {
      "rule_id": "short_circuit.gb.electrical_life_split_30",
      "domain": "short_circuit",
      "kind": "split",
      "standard": "gb",
      "test_item": "电寿命试验",
      "status": "active",
      "inputs": {
        "trigger_when_any": [
          {
            "type": "all",
            "conditions": [
              {
                "source": "query",
                "type": "contains",
                "label": "短路性能型式试验"
              },
              {
                "source": "query",
                "type": "regex_match",
                "pattern": "电寿命(?:试验|等级)?(?:[^\\n]{0,20})?30次|30次(?:[^\\n]{0,20})?电寿命(?:试验|等级)?"
